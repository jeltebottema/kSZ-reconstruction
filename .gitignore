# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environment
.venv/
venv/
env/

# uv lockfile (commit if reproducible installs are wanted across machines; safer to commit)
# uv.lock

# Data files (large, kept local)
data/
data_*/
**/data/
**/data_*/
cache/

# Plots and figures (regenerable, kept local)
plots/
plots_*/
**/plots/
**/plots_*/
*.png
*.jpg
*.jpeg

# But keep paper-figure PDFs (small, version them)
!**/plots_paper/*.pdf

# Notebooks checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# IDL / external code artifacts
*.pro

# Loose top-level scratch outputs
/output.png
/noise.png
/target_vs_pred.png
/train_progress.png

# Large archive zips (e.g. noisy_reconstruction.zip)
*.zip

# Local Claude Code orientation files — not shared
